# Protect sensitive files
<Files "config.php">
    Require all denied
</Files>

<Files "*.db">
    Require all denied
</Files>

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Cache static assets
<FilesMatch "\.(jpg|jpeg|png|gif|ico|css|js)$">
    Header set Cache-Control "public, max-age=2592000"
</FilesMatch>

# Compress text files
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json application/rss+xml
</IfModule>

# Security Headers
<IfModule mod_headers.c>
    # Allow embedding from same domain and all subdomains of darcynorman.net
    Header set Content-Security-Policy "frame-ancestors 'self' https://*.darcynorman.net"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    # Uncomment HSTS if using HTTPS
    # Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Protect sensitive directories
<IfModule mod_authz_core.c>
    <DirectoryMatch "(^|/)(\.git|includes|sessions)/">
        Require all denied
    </DirectoryMatch>
</IfModule>
<IfModule !mod_authz_core.c>
    <DirectoryMatch "(^|/)(\.git|includes|sessions)/">
        Order deny,allow
        Deny from all
    </DirectoryMatch>
</IfModule>

# Block Google crawler IP range (66.249.x.x) - Googlebot hammering server
<IfModule mod_authz_core.c>
    Require not ip 66.249.0.0/16
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Allow from all
    Deny from 66.249.0.0/16
</IfModule>

# Block distributed crawlers that systematically enumerate tag combinations.
# Legitimate users rarely combine more than 4-5 tags; bots generate 6-10+ tag URLs.
# %2C is a URL-encoded comma; 2+ occurrences means 3+ tags in the query string.
RewriteCond %{QUERY_STRING} (%2C.*){2} [NC]
RewriteRule ^ - [G,L]

# Block aggressive bots and AI crawlers by user-agent (hard block, ignores robots.txt)
RewriteEngine On
RewriteCond %{HTTP_USER_AGENT} (GPTBot|ChatGPT-User|anthropic-ai|Claude-Web|ClaudeBot|CCBot|Bytespider|Amazonbot|Diffbot|ImagesiftBot|omgili|AhrefsBot|SemrushBot|DotBot|MJ12bot|DataForSeoBot|PetalBot|BLEXBot|magpie-crawler) [NC]
RewriteRule ^ - [F,L]

# Block requests with no user-agent (many bots/scripts omit it)
RewriteCond %{HTTP_USER_AGENT} ^$
RewriteRule ^ - [F,L]

# Force HTTPS (Uncomment to enable)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L,QSA]